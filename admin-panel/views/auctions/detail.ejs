<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('../partials/head') %>
</head>
<body class="layout-main">
  <div class="app-wrapper">
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <%- include('../partials/header') %>

      <main class="content-area">
        <div class="page-header">
          <div>
            <a href="/auctions" class="btn btn-sm btn-outline btn-back">
              <i data-lucide="arrow-left"></i> Back
            </a>
            <h2>Auction #<%= auction.id %></h2>
            <p class="page-subtitle">Auction Detail</p>
          </div>
          <div class="page-header-actions">
            <% if (auction.status === 'active') { %>
              <form action="/auctions/<%= auction.id %>/cancel" method="POST" style="display:inline" onsubmit="return confirm('Are you sure you want to cancel this auction?')">
                <button type="submit" class="btn btn-danger btn-sm" id="cancelAuctionBtn">
                  <i data-lucide="x-circle"></i> Cancel Auction
                </button>
              </form>
            <% } %>
          </div>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger">
            <i data-lucide="alert-circle"></i>
            <span><%= error %></span>
          </div>
        <% } %>

        <div class="detail-grid">
          <!-- Auction Info -->
          <div class="card detail-card">
            <div class="card-header">
              <h3><i data-lucide="timer"></i> Auction Information</h3>
              <span class="badge badge-lg badge-<%= auction.status === 'active' ? 'success' : auction.status === 'closed' ? 'primary' : auction.status === 'cancelled' ? 'danger' : 'warning' %>">
                <%= auction.status.toUpperCase() %>
              </span>
            </div>
            <div class="card-body">
              <div class="detail-fields">
                <div class="detail-field">
                  <span class="detail-label">Item</span>
                  <span class="detail-value">
                    <% if (auction.item) { %>
                      <a href="/items/<%= auction.item.id %>" class="link"><%= auction.item.title %></a>
                    <% } else { %>
                      N/A
                    <% } %>
                  </span>
                </div>
                <div class="detail-field">
                  <span class="detail-label">Category</span>
                  <span class="detail-value"><span class="badge badge-default"><%= auction.item ? auction.item.category : '—' %></span></span>
                </div>
                <div class="detail-field">
                  <span class="detail-label">Seller</span>
                  <span class="detail-value">
                    <% if (auction.seller) { %>
                      <a href="/users/<%= auction.seller.id %>" class="link"><%= auction.seller.name %></a>
                    <% } else { %>
                      N/A
                    <% } %>
                  </span>
                </div>
                <div class="detail-field">
                  <span class="detail-label">Start Price</span>
                  <span class="detail-value">Rp <%= Number(auction.start_price).toLocaleString('id-ID') %></span>
                </div>
                <div class="detail-field">
                  <span class="detail-label">Current Price</span>
                  <span class="detail-value text-currency" style="font-size:1.25rem;font-weight:700;">Rp <%= Number(auction.current_price).toLocaleString('id-ID') %></span>
                </div>
                <div class="detail-field">
                  <span class="detail-label">Buyout Price</span>
                  <span class="detail-value"><%= auction.buyout_price ? 'Rp ' + Number(auction.buyout_price).toLocaleString('id-ID') : '—' %></span>
                </div>
                <div class="detail-field">
                  <span class="detail-label">Start Time</span>
                  <span class="detail-value"><%= new Date(auction.start_time).toLocaleString('id-ID') %></span>
                </div>
                <div class="detail-field">
                  <span class="detail-label">End Time</span>
                  <span class="detail-value">
                    <% if (auction.status === 'active') { %>
                      <span class="countdown" data-end="<%= auction.end_time %>"><%= new Date(auction.end_time).toLocaleString('id-ID') %></span>
                    <% } else { %>
                      <%= new Date(auction.end_time).toLocaleString('id-ID') %>
                    <% } %>
                  </span>
                </div>
                <% if (auction.winner) { %>
                  <div class="detail-field">
                    <span class="detail-label">Winner</span>
                    <span class="detail-value">
                      <span class="badge badge-success"><i data-lucide="trophy" style="width:12px;height:12px"></i></span>
                      <a href="/users/<%= auction.winner.id %>" class="link"><%= auction.winner.name %></a>
                    </span>
                  </div>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Item Preview -->
          <div class="card detail-card">
            <div class="card-header">
              <h3><i data-lucide="image"></i> Item Preview</h3>
            </div>
            <div class="card-body">
              <% if (auction.item && auction.item.image_urls && auction.item.image_urls.length > 0) { %>
                <div class="image-gallery">
                  <div class="gallery-main">
                    <img src="<%= auction.item.image_urls[0].startsWith('http') ? auction.item.image_urls[0] : API_BASE_URL + '/' + auction.item.image_urls[0] %>" alt="<%= auction.item.title %>">
                  </div>
                </div>
              <% } else { %>
                <div class="empty-state">
                  <i data-lucide="image-off"></i>
                  <p>No item images</p>
                </div>
              <% } %>
              <% if (auction.item) { %>
                <p style="margin-top:1rem;color:var(--text-secondary);"><%= auction.item.description || 'No description' %></p>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Bid History -->
        <div class="card" style="margin-top:1.5rem;">
          <div class="card-header">
            <h3><i data-lucide="list"></i> Bid History</h3>
            <span class="badge badge-default"><%= bids.length %> bid(s)</span>
          </div>
          <div class="card-body">
            <% if (bids.length === 0) { %>
              <div class="empty-state">
                <i data-lucide="inbox"></i>
                <p>No bids placed yet</p>
              </div>
            <% } else { %>
              <div class="bid-timeline">
                <% bids.sort((a,b) => new Date(b.created_at) - new Date(a.created_at)).forEach(function(bid, idx) { %>
                  <div class="bid-entry <%= idx === 0 ? 'bid-highest' : '' %>">
                    <div class="bid-marker"></div>
                    <div class="bid-content">
                      <div class="bid-amount">Rp <%= Number(bid.amount).toLocaleString('id-ID') %></div>
                      <div class="bid-meta">
                        <span>Bidder #<%= bid.bidder_id %></span>
                        <span class="text-muted"><%= new Date(bid.created_at).toLocaleString('id-ID') %></span>
                      </div>
                    </div>
                    <% if (idx === 0) { %>
                      <span class="badge badge-success">Highest</span>
                    <% } %>
                  </div>
                <% }); %>
              </div>
            <% } %>
          </div>
        </div>
      </main>

      <%- include('../partials/footer') %>
    </div>
  </div>

  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
</body>
</html>
