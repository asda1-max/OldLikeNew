<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('../partials/head') %>
</head>
<body class="layout-main">
  <div class="app-wrapper">
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <%- include('../partials/header') %>

      <main class="content-area">
        <div class="page-header">
          <h2>Dashboard</h2>
          <p class="page-subtitle">Overview of your auction platform</p>
        </div>

        <!-- Stats Cards -->
        <div class="stats-grid">
          <div class="stat-card stat-card-gradient-1">
            <div class="stat-icon">
              <i data-lucide="users"></i>
            </div>
            <div class="stat-info">
              <span class="stat-value" data-count="<%= stats.totalUsers %>">0</span>
              <span class="stat-label">Total Users</span>
            </div>
          </div>

          <div class="stat-card stat-card-gradient-2">
            <div class="stat-icon">
              <i data-lucide="timer"></i>
            </div>
            <div class="stat-info">
              <span class="stat-value" data-count="<%= stats.totalActiveAuctions %>">0</span>
              <span class="stat-label">Active Auctions</span>
            </div>
          </div>

          <div class="stat-card stat-card-gradient-3">
            <div class="stat-icon">
              <i data-lucide="credit-card"></i>
            </div>
            <div class="stat-info">
              <span class="stat-value" data-count="<%= stats.totalTransactions %>">0</span>
              <span class="stat-label">Transactions</span>
            </div>
          </div>

          <div class="stat-card stat-card-gradient-4">
            <div class="stat-icon">
              <i data-lucide="trending-up"></i>
            </div>
            <div class="stat-info">
              <span class="stat-value stat-currency" data-count="<%= stats.totalRevenue %>">0</span>
              <span class="stat-label">Total Revenue</span>
            </div>
          </div>
        </div>

        <!-- Charts Row -->
        <div class="charts-grid">
          <div class="card chart-card">
            <div class="card-header">
              <h3><i data-lucide="pie-chart"></i> Payment Status</h3>
            </div>
            <div class="card-body chart-container">
              <canvas id="paymentChart"></canvas>
            </div>
          </div>

          <div class="card chart-card">
            <div class="card-header">
              <h3><i data-lucide="bar-chart-3"></i> Categories</h3>
            </div>
            <div class="card-body chart-container">
              <canvas id="categoryChart"></canvas>
            </div>
          </div>

          <div class="card chart-card">
            <div class="card-header">
              <h3><i data-lucide="users"></i> User Roles</h3>
            </div>
            <div class="card-body chart-container">
              <canvas id="roleChart"></canvas>
            </div>
          </div>
        </div>

        <!-- Recent Transactions -->
        <div class="card">
          <div class="card-header">
            <h3><i data-lucide="clock"></i> Recent Transactions</h3>
            <a href="/transactions" class="btn btn-sm btn-outline">View All</a>
          </div>
          <div class="card-body">
            <% if (recentTransactions.length === 0) { %>
              <div class="empty-state">
                <i data-lucide="inbox"></i>
                <p>No transactions yet</p>
              </div>
            <% } else { %>
              <div class="table-responsive">
                <table class="data-table" id="recentTransactionsTable">
                  <thead>
                    <tr>
                      <th>ID</th>
                      <th>Auction</th>
                      <th>Price</th>
                      <th>Payment</th>
                      <th>Shipping</th>
                      <th>Date</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% recentTransactions.forEach(function(t) { %>
                      <tr>
                        <td><span class="id-badge">#<%= t.id %></span></td>
                        <td><a href="/auctions/<%= t.auction_id %>" class="link">Auction #<%= t.auction_id %></a></td>
                        <td class="text-currency">Rp <%= Number(t.final_price).toLocaleString('id-ID') %></td>
                        <td><span class="badge badge-<%= t.payment_status === 'paid' ? 'success' : t.payment_status === 'cancelled' ? 'danger' : 'warning' %>"><%= t.payment_status %></span></td>
                        <td><span class="badge badge-<%= t.shipping_status === 'delivered' ? 'success' : t.shipping_status === 'shipped' ? 'info' : 'warning' %>"><%= t.shipping_status %></span></td>
                        <td class="text-muted"><%= new Date(t.created_at).toLocaleDateString('id-ID') %></td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>
      </main>

      <%- include('../partials/footer') %>
    </div>
  </div>

  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- Chart Data -->
  <script>
    window.__chartData = {
      paymentStatus: <%- JSON.stringify(paymentStatusCounts) %>,
      categories: <%- JSON.stringify(categoryCounts) %>,
      roles: <%- JSON.stringify(roleCounts) %>,
    };
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
